# Copy to .env and adjust values before running docker compose.

# Port the game is exposed on
PORT=3000

# Secret used to sign session cookies. MUST be a long random string (>= 16
# chars) — with NODE_ENV=production the server refuses to start otherwise,
# since a known secret lets anyone forge a login cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Set to "production" for a real deployment (enables the strict secret check).
NODE_ENV=production

# Set to "true" when serving over HTTPS (behind a TLS-terminating reverse
# proxy) so session cookies carry the Secure flag. Leave unset for plain
# HTTP / local play, or cookies won't be sent.
SECURE_COOKIES=false

# Postgres credentials (used by both the db and game services)
POSTGRES_USER=game
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=game
